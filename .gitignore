# ============================================
# Y-Store TMA .gitignore
# ============================================

# --- Secrets ---
.env
*.env
!*.env.example
!env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
venv/
env/
.venv/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# --- React build ---
frontend/build/
frontend/.cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- MongoDB ---
*.bson
dump/

# --- Temporary ---
tmp/
temp/
*.tmp
*.bak
*.orig

# --- Test reports ---
test_reports/
coverage/

# --- Emergent ---
.emergent/

# --- OS ---
.DS_Store
._.DS_Store
._*

# --- Plan tool artifacts (dev-only) ---
memory/test_credentials.md
frontend/node_modules/.cache/default-development/8.pack
frontend/node_modules/.cache/default-development/7.pack
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
